{
  "version": 1,
  "author": "Mariem Sibba",
  "editor": "wokwi",
  "parts": [
    { "type": "board-esp32-devkit-c-v4", "id": "esp", "top": 100, "left": 200, "attrs": {} },
    { "type": "wokwi-ntc-temperature-sensor", "id": "ntc1", "top": 20, "left": 20, "attrs": { "temperature": "121" } },
    { "type": "wokwi-potentiometer", "id": "pot1", "top": 250, "left": 20, "attrs": { "label": "Torque" } },
    { "type": "wokwi-potentiometer", "id": "pot2", "top": 20, "left": 450, "attrs": { "label": "Vibration" } },
    { "type": "wokwi-led", "id": "led_ok",   "top": 420, "left": 100, "attrs": { "color": "green"  } },
    { "type": "wokwi-led", "id": "led_warn", "top": 420, "left": 160, "attrs": { "color": "yellow" } },
    { "type": "wokwi-led", "id": "led_err",  "top": 420, "left": 220, "attrs": { "color": "red"    } },
    { "type": "wokwi-resistor", "id": "r1", "top": 480, "left": 100, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r2", "top": 480, "left": 160, "attrs": { "value": "220" } },
    { "type": "wokwi-resistor", "id": "r3", "top": 480, "left": 220, "attrs": { "value": "220" } }
  ],
  "connections": [
    [ "esp:TX", "$serialMonitor:RX", "", [] ],
    [ "esp:RX", "$serialMonitor:TX", "", [] ],

    [ "ntc1:VCC", "esp:3V3",   "red",   [] ],
    [ "ntc1:GND", "esp:GND.1", "black", [] ],
    [ "ntc1:OUT", "esp:35",    "green", [] ],

    [ "pot1:VCC", "esp:3V3",   "red",    [] ],
    [ "pot1:GND", "esp:GND.1", "black",  [] ],
    [ "pot1:SIG", "esp:34",    "yellow", [] ],

    [ "pot2:VCC", "esp:3V3",   "red",    [] ],
    [ "pot2:GND", "esp:GND.1", "black",  [] ],
    [ "pot2:SIG", "esp:32",    "orange", [] ],

    [ "esp:25", "r1:1", "limegreen", [] ],
    [ "r1:2", "led_ok:A",   "limegreen", [] ],
    [ "led_ok:K", "esp:GND.2", "black", [] ],

    [ "esp:26", "r2:1", "gold", [] ],
    [ "r2:2", "led_warn:A", "gold", [] ],
    [ "led_warn:K", "esp:GND.2", "black", [] ],

    [ "esp:27", "r3:1", "red", [] ],
    [ "r3:2", "led_err:A", "red", [] ],
    [ "led_err:K", "esp:GND.2", "black", [] ]
  ],
  "dependencies": {}
}